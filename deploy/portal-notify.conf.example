# /etc/portal-notify.conf へコピーして編集する。
#   sudo cp deploy/portal-notify.conf.example /etc/portal-notify.conf
#   sudo vi /etc/portal-notify.conf
# notify.sh がこのファイルを読み込みます。

# Discord の Webhook URL（チャンネル設定 → 連携サービス → ウェブフック で作成）
DISCORD_WEBHOOK="https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx"

# 公開ドメイン（SSL証明書の残り日数チェックに使用）
DOMAIN="madgear.sytes.net"
SITE_URL="https://madgear.sytes.net"

# 体験終了日（分かれば YYYY-MM-DD。空でも可。分かり次第ここに記入）
TRIAL_END=""

# 認証間隔（日）: 旧仕様用。下の HOURS を設定するとそちらが優先される
REAUTH_INTERVAL_DAYS="4"

# 認証間隔（時間）: 新仕様（24時間で終了・12時間ごとに更新）なら "12" を設定。
# 設定すると時間単位のカウントダウンになり、更新のたびに
#   sudo /var/www/portal/deploy/renewed.sh
# を実行すれば「残り◯時間」が正確になる（残り3時間で毎時@everyone）
REAUTH_INTERVAL_HOURS="12"

# XServerの更新ページURL（リマインドに添付。実際の更新画面のURLに変えてもOK）
RENEW_PANEL_URL="https://secure.xserver.ne.jp/xapanel/login/xvps/"

# no-ip を最後に確認した日（YYYY-MM-DD）。23日目に🟠・27日目に🔴@everyone。
# 確認するたびに手で書くか、 sudo deploy/noip-confirmed.sh を実行すると今日付で自動記録
NOIP_LAST_CONFIRMED=""

# healthchecks.io の ping URL（無料登録 → Check 作成で取得。死活監視。任意）
HEALTHCHECK_URL=""

# 通知に出す名前
HOST_LABEL="身内ポータル"

# LINE 通知（任意）: Messaging API のチャネルアクセストークン。Botを友だち追加した人全員に届く
LINE_TOKEN=""
# LINEは無料枠が月200通(配信数×友だち人数)。1=緊急時のみ送る(推奨)。0=毎回送る
# 毎朝の「稼働中✅」までLINEに流すと枠を使い切って月末まで届かなくなる
LINE_URGENT_ONLY="1"

# メモリ使用率アラートのしきい値（%。これ以上でDiscord/LINEに警告）
MEM_ALERT_THRESHOLD="85"

# ===== オフサイト・バックアップ（backup-to-discord.sh 用）=====
# DBを毎日Discordへ退避してVPS全損に備える。守るべきはDBファイル。
# バックアップ専用チャンネルのWebhook（空なら上の DISCORD_WEBHOOK を流用）
BACKUP_WEBHOOK=""
# 暗号化パスフレーズ（ユーザーデータをDiscordに置くため設定を強く推奨）。
# ※このパスフレーズは復元に必須。パスワードマネージャ等でVPSの外に控えること
BACKUP_PASSPHRASE=""
