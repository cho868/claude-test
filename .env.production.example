APP_NAME="身内ポータル"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Tokyo
# no-ip 等で取得したホスト名に置き換える（HTTPS化後は https:// に）
APP_URL=https://example.ddns.net

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# 身内規模なら SQLite が手軽（DBサーバー不要・省メモリ）
DB_CONNECTION=sqlite
# MySQL/MariaDB を使う場合は以下を有効化:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=portal
# DB_USERNAME=portal
# DB_PASSWORD=ここに強いパスワード

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS 化（certbot 実行後）に true 推奨。http のうちは false のままで。
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.ddns.net"
MAIL_FROM_NAME="${APP_NAME}"

# 外部連携（任意）
STEAM_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# 新規登録の招待コード（身内以外の登録を防ぐ。例: ランダムな文字列を設定して身内に共有）
REGISTRATION_INVITE_CODE=
